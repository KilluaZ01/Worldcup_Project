# Example .env for local development (DO NOT commit real credentials)
# For Neon, prefer the pooler host for connection stability.
# Example (replace placeholders):
# postgresql+psycopg://<ROLE>:<PASSWORD>@<POOLER_HOST>/<DB_NAME>?sslmode=require

DATABASE_URL=postgresql+psycopg://<ROLE>:<PASSWORD>@<POOLER_HOST>/<DB_NAME>?sslmode=require
APP_NAME=Bet Tracker API
ALLOWED_ORIGINS=http://localhost:5173
SPORTS_API_URL=
SPORTS_API_KEY=
SPORTS_API_LEAGUE=39
SPORTS_API_SEASON=2026
